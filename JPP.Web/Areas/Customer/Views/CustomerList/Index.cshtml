@{
    ViewData["Title"] = "Customer List";
    ViewData["PageTitle"] = "Customer List";
    ViewData["PageSubtitle"] = "Manage customer data";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div ng-app="customerListApp"
     ng-controller="CustomerListController"
     ng-cloak>

    @Html.AntiForgeryToken()

    <div class="admin-page-header mb-4">
        <div>
            <span class="admin-eyebrow">Customer</span>
            <h3>Customer List</h3>
            <p>Manage customer master data including name, address, and phone number.</p>
        </div>

        <div class="admin-page-actions">
            <a href="/Customer/CustomerAdd/CustomerAddPage"
               class="btn btn-main">
                <i class="bi bi-plus-lg me-2"></i>
                Add
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-success alert-dismissible fade show" role="alert" ng-if="alert.type === 'success'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="alert alert-danger alert-dismissible fade show" role="alert" ng-if="alert.type === 'danger'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="crm-card mb-4">
        <div class="section-title">
            <h5>Filter Customer</h5>
        </div>

        <form ng-submit="searchCustomers()">
            <div class="row g-3 align-items-end">
                <div class="col-xl-4 col-md-6">
                    <label class="form-label admin-form-label">Keyword</label>
                    <div class="admin-input-icon">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               ng-model="filter.keyword"
                               class="form-control"
                               placeholder="Search by name, address, or phone" />
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <label class="form-label admin-form-label">Store</label>
                    <select ng-model="filter.storeId" class="form-select">
                        <option ng-value="0">All</option>
                        <option ng-repeat="store in storeOptions" ng-value="store.id || store.Id">{{ store.name || store.Name }}</option>
                    </select>
                </div>

                <div class="col-xl-3 col-md-6">
                    <label class="form-label admin-form-label">Event</label>
                    <select ng-model="filter.eventId" class="form-select">
                        <option ng-value="0">All</option>
                        <option ng-repeat="event in eventOptions" ng-value="event.id || event.Id">{{ event.name || event.Name }}</option>
                    </select>
                </div>

                <div class="col-xl-2 col-md-12 d-flex gap-2">
                    <button type="submit" class="btn btn-main flex-fill" ng-disabled="isBusy()">
                        <i class="bi bi-search me-2"></i> Search
                    </button>
                    <button type="button" class="btn btn-soft" ng-click="resetFilter()" ng-disabled="isBusy()">
                        Reset
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="crm-card store-table-card">
        <div class="store-table-header">
            <div>
                <h5>Customer Data</h5>
                <p>
                    Showing
                    <span ng-bind="customers.length"></span>
                    customer record(s)
                </p>
            </div>

            <button type="button"
                    class="btn btn-soft btn-sm"
                    ng-click="loadCustomers(true)"
                    ng-disabled="isBusy()">
                <i class="bi bi-arrow-clockwise me-1" ng-class="{ 'store-spin': isBusy() }"></i>
                Refresh
            </button>
        </div>

        <div class="table-responsive store-table-wrapper store-table-scroll">
            <table class="table align-middle store-table">
                <thead>
                    <tr>
                        <th>Acc No</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Age</th>
                        <th>Address</th>
                        <th>Kecamatan</th>
                        <th>Skin</th>
                        <th>Dental</th>
                        <th class="text-center action-col">Action</th>
                    </tr>
                </thead>

                <tbody>
                    <tr ng-repeat="customer in customers track by $index">
                        <td data-label="Acc No">
                            <span ng-bind="customer.accNo || customer.AccNo || '-'"></span>
                        </td>
                        <td data-label="Name">
                            <span ng-bind="customer.fullName || customer.FullName || '-'"></span>
                        </td>
                        <td data-label="Phone Number">
                            <span class="store-phone" ng-if="customer.phoneNumber || customer.PhoneNumber">
                                <i class="bi bi-telephone me-1"></i>
                                <span ng-bind="customer.phoneNumber || customer.PhoneNumber"></span>
                            </span>
                            <span class="text-muted" ng-if="!customer.phoneNumber && !customer.PhoneNumber">-</span>
                        </td>
                        <td data-label="Age">
                            <span ng-bind="customer.age || customer.Age || '-'"></span>
                        </td>
                        <td data-label="Address">
                            <span ng-bind="customer.address1 || customer.Address1 || '-'"></span>
                        </td>
                        <td data-label="Kecamatan">
                            <span ng-bind="customer.kecamatan || customer.Kecamatan || '-'"></span>
                        </td>

                        <td data-label="Skin">
                            <span ng-bind="customer.skin || customer.Skin || 'No'"></span>
                        </td>
                        <td data-label="Dental">
                            <span ng-bind="customer.dental || customer.Dental || 'No'"></span>
                        </td>
                        <td class="text-center action-sticky action-col" data-label="Action">
                            <div class="table-action-icons d-flex justify-content-center gap-1">
                                <a href="/Customer/CustomerEdit/Edit?id={{ customer.customerID || customer.CustomerID || customer.Id }}"
                                   class="btn-action-icon btn-edit"
                                   title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <button type="button"
                                        class="btn-action-icon text-primary"
                                        style="background-color: #e7f1ff; border-color: #cce5ff; border-style: solid; border-width: 1px;"
                                        title="Diagnostic"
                                        ng-click="openDiagnosticModal(customer)">
                                    <i class="bi bi-clipboard2-pulse"></i>
                                </button>

                                <button type="button"
                                        class="btn-action-icon text-success"
                                        style="background-color: #d1e7dd; border-color: #badbcc; border-style: solid; border-width: 1px;"
                                        title="Assign Event"
                                        ng-click="openEventModal(customer)">
                                    <i class="bi bi-calendar-plus"></i>
                                </button>

                                <button type="button"
                                        class="btn-action-icon btn-delete"
                                        title="Delete Customer"
                                        ng-click="openDeleteConfirmation(customer)">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- EVENT MODAL -->
    <div class="delete-confirm-backdrop" ng-if="eventModal.visible" ng-click="closeEventModal()" ng-cloak>
        <div class="custom-bottom-right-panel shadow"
            ng-click="$event.stopPropagation()"
            style="position: static; top: auto; left: auto; right: auto; bottom: auto; transform: none; width: 550px; max-width: 90vw; max-height: 85vh; display: flex; flex-direction: column;">

            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-white" style="border-radius: 8px 8px 0 0;">
                <span class="fw-bold text-dark" style="font-size: 0.95rem;">
                    {{ eventModal.customer.fullName || eventModal.customer.FullName }}
                </span>
                <button type="button" class="btn-close" style="font-size: 0.75rem;" ng-click="closeEventModal()"></button>
            </div>

            <!-- Assigned events table (Event | Date) -->
            <div class="p-3 overflow-auto bg-white" style="max-height: 30vh;">
                <div class="text-center my-3" ng-if="eventModal.isLoadingCustomerEvents">
                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                    <div class="small mt-2 text-muted">Loading events...</div>
                </div>

                <table class="table table-sm mb-0" ng-if="!eventModal.isLoadingCustomerEvents && eventModal.customerEvents.length > 0">
                    <thead>
                        <tr>
                            <th style="font-size: 0.8rem;">Event</th>
                            <th style="font-size: 0.8rem;">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="ce in eventModal.customerEvents">
                            <td style="font-size: 0.85rem;" ng-bind="ce.name || ce.Name"></td>
                            <td style="font-size: 0.85rem;" ng-bind="formatEventDate(ce.eventDateTime || ce.EventDateTime)"></td>
                        </tr>
                    </tbody>
                </table>

                <div class="text-center text-muted small py-2" ng-if="!eventModal.isLoadingCustomerEvents && eventModal.customerEvents.length === 0">
                    No events assigned yet.
                </div>
            </div>

            <!-- Event picker, shown when "Event List" is toggled on -->
            <div class="p-3 overflow-auto bg-white border-top" ng-if="eventModal.showEventList" style="max-height: 30vh;">
                <div class="text-center my-3" ng-if="eventModal.isLoading">
                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                    <div class="small mt-2 text-muted">Loading events...</div>
                </div>

                <div class="text-center text-muted small py-2" ng-if="!eventModal.isLoading && eventModal.events.length === 0">
                    No events available.
                </div>

                <div ng-if="!eventModal.isLoading && eventModal.events.length > 0">
                    <div class="d-flex align-items-start mb-2 border-bottom pb-2" ng-repeat="event in eventModal.events">
                        <input class="form-check-input mt-1 me-2"
                            type="checkbox"
                            id="eventCheck_{{ event.id || event.Id }}"
                            value="{{ event.id || event.Id }}"
                            ng-checked="eventModal.selectedIds.includes(event.id || event.Id)"
                            ng-click="toggleEventSelection(event.id || event.Id)"
                            style="cursor: pointer;">
                        <label for="eventCheck_{{ event.id || event.Id }}" style="cursor: pointer; width: 100%;">
                            <div class="fw-medium text-dark" style="font-size: 0.85rem;">{{ event.name || event.Name }}</div>
                            <div class="text-muted" style="font-size: 0.75rem;">{{ event.code || event.Code }}</div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="p-3 border-top bg-white mt-auto" style="border-radius: 0 0 8px 8px;">
                <div class="alert alert-danger mb-3"
                    ng-if="eventModal.errorMessage">
                    {{ eventModal.errorMessage }}
                </div>

                <div class="d-flex justify-content-end mb-2"
                    ng-if="eventModal.showEventList">
                    <span class="text-muted" style="font-size:0.75rem;">
                        {{ eventModal.selectedIds.length }} selected
                    </span>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-medium text-dark">Event</span>

                    <div class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-main btn-sm"
                                ng-click="toggleEventListView()">
                            Event List
                        </button>

                        <button type="button"
                                class="btn btn-main btn-sm"
                                ng-click="saveCustomerEvents()"
                                ng-disabled="eventModal.selectedIds.length === 0 || eventModal.isSaving">
                            <span class="spinner-border spinner-border-sm"
                                ng-if="eventModal.isSaving"></span>
                            <span ng-if="!eventModal.isSaving">Add</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @await Html.PartialAsync("Diagnostic")
    <div class="delete-confirm-backdrop"
        ng-if="deleteModal.visible"
        ng-click="closeDeleteConfirmation()">

        <div class="delete-confirm-modal"
            ng-click="$event.stopPropagation()">

            <div class="delete-confirm-header">
                <div class="delete-confirm-icon">
                    <i class="bi bi-trash3"></i>
                </div>

                <div>
                    <h5>Delete Customer?</h5>
                    <p>This action will remove the customer record.</p>
                </div>

                <button type="button"
                        class="delete-confirm-close"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="delete-confirm-body">
                <div class="delete-store-preview">
                    <div class="delete-store-avatar">
                        <i class="bi bi-person"></i>
                    </div>

                    <div class="delete-store-info">
                        <strong ng-bind="deleteModal.customer.fullName || deleteModal.customer.FullName || '-'"></strong>
                        <div>
                            <span ng-if="deleteModal.customer.accNo || deleteModal.customer.AccNo">
                                {{ deleteModal.customer.accNo || deleteModal.customer.AccNo }}
                            </span>
                        </div>
                    </div>
                </div>

                <div class="delete-warning-box">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>
                        Are you sure you want to delete this customer? This customer will no longer appear in the list.
                    </span>
                </div>

                <div class="delete-error-box" ng-if="deleteModal.errorMessage">
                    <i class="bi bi-x-circle"></i>
                    <span ng-bind="deleteModal.errorMessage"></span>
                </div>
            </div>

            <div class="delete-confirm-actions">
                <button type="button"
                        class="btn btn-soft"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-delete-confirm"
                        ng-click="confirmDeleteCustomer()"
                        ng-disabled="isDeleting">
                    <span class="spinner-border spinner-border-sm me-2"
                        ng-if="isDeleting"></span>
                    <i class="bi bi-trash3 me-2"
                    ng-if="!isDeleting"></i>
                    <span ng-if="!isDeleting">Yes, Delete Customer</span>
                    <span ng-if="isDeleting">Deleting...</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            angular
                .module('customerListApp', [])
                .controller('CustomerListController', CustomerListController);

            CustomerListController.$inject = ['$scope', '$timeout', '$http'];

            function CustomerListController($scope, $timeout, $http) {
                var allCustomers = [];

                $scope.diagnosticModal = {
                    visible: false,
                    isLoading: false,
                    isSaving: false,
                    customer: null,
                    entries: [],
                    errorMessage: '',
                    newEntry: { type: 'Skin', note: '' }
                };

                $scope.openDiagnosticModal = openDiagnosticModal;
                $scope.closeDiagnosticModal = closeDiagnosticModal;
                $scope.saveDiagnosticEntry = saveDiagnosticEntry;

                $scope.eventModal = {
                    visible: false,
                    isLoading: false,
                    isSaving: false,
                    isLoadingCustomerEvents: false,
                    customer: null,
                    events: [],
                    customerEvents: [],
                    selectedIds: [],
                    showEventList: false,
                    errorMessage: ''
                };

                $scope.openEventModal = openEventModal;
                $scope.closeEventModal = closeEventModal;
                $scope.toggleEventSelection = toggleEventSelection;
                $scope.saveCustomerEvents = saveCustomerEvents;
                $scope.toggleEventListView = toggleEventListView;
                $scope.formatEventDate = formatEventDate;

                $scope.deleteModal = {
                    visible: false,
                    customer: null,
                    errorMessage: ''
                };
                $scope.isDeleting = false;

                $scope.sort = {
                    column: 'fullName',
                    direction: 'ASC'
                };

                $scope.alert = {
                    type: '',
                    message: ''
                };

                $scope.filter = {
                    keyword: '',
                    storeId: 0,
                    eventId: 0
                };

                $scope.storeOptions = [];
                $scope.eventOptions = [];
                $scope.searchCustomers = searchCustomers;
                $scope.resetFilter = resetFilter;
                $scope.loadCustomers = loadCustomers;
                $scope.changeSort = changeSort;
                $scope.isSorted = isSorted;
                $scope.getSortIcon = getSortIcon;
                $scope.isBusy = isBusy;
                $scope.clearAlert = clearAlert;
                $scope.openDeleteConfirmation = openDeleteConfirmation;
                $scope.closeDeleteConfirmation = closeDeleteConfirmation;
                $scope.confirmDeleteCustomer = confirmDeleteCustomer;

                loadFilterOptions();
                loadCustomers();

                function openEventModal(customer) {
                    if (!customer) return;

                    var customerId = customer.customerID || customer.CustomerID || customer.Id;

                    $scope.eventModal.errorMessage = '';
                    $scope.eventModal.customer = customer;
                    $scope.eventModal.selectedIds = [];
                    $scope.eventModal.visible = true;
                    $scope.eventModal.showEventList = false;
                    $scope.eventModal.customerEvents = [];
                    $scope.eventModal.isLoading = true;

                    $http.get('/Customer/CustomerList/GetEventOptions')
                        .then(function (response) {
                            $scope.eventModal.events = response.data || [];
                            $scope.eventModal.isLoading = false;
                        })
                        .catch(function (error) {
                            $scope.eventModal.isLoading = false;
                            showAlert('danger', 'Failed to load event list.');
                        });

                    loadCustomerEvents(customerId);
                }

                function loadCustomerEvents(customerId) {
                    if (!customerId) return;

                    $scope.eventModal.isLoadingCustomerEvents = true;

                    $http.get('/Customer/CustomerList/GetCustomerEvents', { params: { customerId: customerId } })
                        .then(function (response) {
                            $scope.eventModal.customerEvents = response.data || [];
                            $scope.eventModal.isLoadingCustomerEvents = false;
                        })
                        .catch(function (error) {
                            $scope.eventModal.isLoadingCustomerEvents = false;
                            showAlert('danger', 'Failed to load assigned events.');
                        });
                }

                function toggleEventListView() {
                    $scope.eventModal.showEventList = !$scope.eventModal.showEventList;
                }

                function formatEventDate(dateValue) {
                    if (!dateValue) return '-';
                    var d = new Date(dateValue);
                    if (isNaN(d.getTime())) return dateValue;
                    var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
                }

                function closeEventModal() {
                    if ($scope.eventModal.isSaving) return;
                    $scope.eventModal.errorMessage = '';
                    $scope.eventModal.visible = false;
                    $scope.eventModal.customer = null;
                    $scope.eventModal.selectedIds = [];
                    $scope.eventModal.customerEvents = [];
                    $scope.eventModal.showEventList = false;
                }

                function toggleEventSelection(eventId) {
                    var index = $scope.eventModal.selectedIds.indexOf(eventId);
                    if (index > -1) {
                        $scope.eventModal.selectedIds.splice(index, 1);
                    } else {
                        $scope.eventModal.selectedIds.push(eventId);
                    }
                }

                function saveCustomerEvents() {
                if ($scope.eventModal.selectedIds.length === 0) return;
                $scope.eventModal.errorMessage = '';

                var duplicateEvents = [];

                $scope.eventModal.selectedIds.forEach(function (selectedId) {

                    var selectedEvent = $scope.eventModal.events.find(function (e) {
                        return (e.id || e.Id) == selectedId;
                    });

                    if (!selectedEvent) return;

                    var selectedName = (selectedEvent.name || selectedEvent.Name || "").trim().toLowerCase();

                    var alreadyExists = $scope.eventModal.customerEvents.some(function (ce) {
                        var customerEventName = (ce.name || ce.Name || "").trim().toLowerCase();
                        return customerEventName === selectedName;
                    });

                    if (alreadyExists) {
                        duplicateEvents.push(selectedEvent.name || selectedEvent.Name);
                    }
                });

                if (duplicateEvents.length > 0) {
                    $scope.eventModal.errorMessage =
                        'This customer is already included in event: ' +
                        duplicateEvents.join(', ');
                    return;
                }

                $scope.eventModal.isSaving = true;

                var customerId =
                    $scope.eventModal.customer.customerID ||
                    $scope.eventModal.customer.CustomerID ||
                    $scope.eventModal.customer.Id;

                var payload = {
                    CustomerId: customerId,
                    EventIds: $scope.eventModal.selectedIds
                };

                $http.post('/Customer/CustomerList/SaveCustomerEvents', payload)
                    .then(function (response) {
                        $scope.eventModal.isSaving = false;

                        if (response.data && response.data.success) {
                            showAlert('success', response.data.message);
                            $scope.eventModal.selectedIds = [];
                            $scope.eventModal.showEventList = false;
                            loadCustomerEvents(customerId);
                        } else {
                            $scope.eventModal.errorMessage =
                                response.data.message || 'Failed to save events.';
                        }
                    })
                    .catch(function (error) {
                        $scope.eventModal.isSaving = false;

                        var errorMessage = 'System error while saving events.';

                        if (error && error.data && error.data.message) {
                            errorMessage = error.data.message;
                        } else if (error && error.data && error.data.Message) {
                            errorMessage = error.data.Message;
                        }

                        showAlert('danger', errorMessage);
                    });
            }


                function openDiagnosticModal(customer) {
                    if (!customer) return;

                    var customerId = customer.customerID || customer.CustomerID || customer.Id;
                    var eventId = customer.eventId || customer.EventId || 0;
                    
                    if (!customerId) return;

                    $scope.diagnosticModal.visible = true;
                    $scope.diagnosticModal.customer = customer;
                    $scope.diagnosticModal.errorMessage = '';
                    $scope.diagnosticModal.newEntry = { type: 'Skin', note: '' };
                    
                    loadDiagnosticEntries(customerId, eventId);
                }

                function closeDiagnosticModal() {
                    if ($scope.diagnosticModal.isSaving) return;
                    $scope.diagnosticModal.visible = false;
                    $scope.diagnosticModal.customer = null;
                    $scope.diagnosticModal.entries = [];
                }

                function loadDiagnosticEntries(customerId, eventId) {
                    $scope.diagnosticModal.isLoading = true;

                    $http.get('/Customer/CustomerList/GetDiagnosticList', { 
                        params: { customerId: customerId, eventId: eventId  } 
                    })
                    .then(function (response) {
                        $scope.diagnosticModal.entries = response.data.data || response.data || [];
                        $scope.diagnosticModal.isLoading = false;
                    })
                    .catch(function (error) {
                        $scope.diagnosticModal.isLoading = false;
                        $scope.diagnosticModal.errorMessage = 'Failed to load diagnostic history.';
                        console.error('Error loading diagnostic list:', error);
                    });
                }

                function saveDiagnosticEntry() {
                    var customer = $scope.diagnosticModal.customer;
                    var customerId = customer.customerID || customer.CustomerID || customer.Id;
                    if (!customerId || !$scope.diagnosticModal.newEntry.note) return;

                    $scope.diagnosticModal.isSaving = true;
                    $scope.diagnosticModal.errorMessage = '';

                    $http.post('/Customer/CustomerList/SaveDiagnostic', {
                        customerId: customerId,
                        type: $scope.diagnosticModal.newEntry.type,
                        description: $scope.diagnosticModal.newEntry.note
                    }).then(function () {
                        $scope.diagnosticModal.newEntry.note = '';
                        loadDiagnosticEntries(customerId);
                        $scope.diagnosticModal.isSaving = false;
                    }).catch(function () {
                        $scope.diagnosticModal.isSaving = false;
                        $scope.diagnosticModal.errorMessage = 'Failed to save diagnostic entry.';
                    });
                }

                function loadFilterOptions() {
                    $http.get('/Customer/CustomerList/GetStoreOptions').then(function (response) {
                        $scope.storeOptions = response.data || [];
                        console.log('Store options loaded:', $scope.storeOptions);
                    }).catch(function (error) {
                        console.error('Error loading store options:', error);
                        $scope.storeOptions = [];
                    });

                    $http.get('/Customer/CustomerList/GetEventOptions').then(function (response) {
                        $scope.eventOptions = response.data || [];
                        console.log('Event options loaded:', $scope.eventOptions);
                    }).catch(function (error) {
                        console.error('Error loading event options:', error);
                        $scope.eventOptions = [];
                    });
                }

                function loadCustomers() {
                    $scope.isLoading = true;
                    clearAlert();

                    $http.get('/Customer/CustomerList/GetCustomerList', {
                        params: {
                            keyword: $scope.filter.keyword,
                            storeId: $scope.filter.storeId,
                            eventId: $scope.filter.eventId,
                            page: 1,
                            pageSize: 20
                        }
                    }).then(function (response) {
                        allCustomers = response.data.data || response.data || [];
                        $scope.customers = allCustomers;
                        applyCustomerSort($scope.customers);
                        $scope.isLoading = false;
                    }).catch(function () {
                        $scope.customers = [];
                        $scope.isLoading = false;
                        showAlert('danger', 'Failed to load customer data.');
                    });
                }

                function applyCustomerFilter() {
                    var filtered = allCustomers || [];

                    if ($scope.filter.keyword) {
                        var keyword = $scope.filter.keyword.toLowerCase();

                        filtered = (allCustomers || []).filter(function (c) {
                            return (c.fullName || '').toLowerCase().includes(keyword) ||
                                   (c.address1 || '').toLowerCase().includes(keyword) ||
                                   (c.phoneNumber || '').toLowerCase().includes(keyword);
                        });
                    }

                    $scope.customers = filtered;
                    applyCustomerSort($scope.customers);
                }

                function changeSort(column) {
                    if ($scope.sort.column === column) {
                        $scope.sort.direction = ($scope.sort.direction === 'ASC') ? 'DESC' : 'ASC';
                    } else {
                        $scope.sort.column = column;
                        $scope.sort.direction = 'ASC';
                    }

                    applyCustomerSort();
                }

                function isSorted(column) {
                    return $scope.sort.column === column;
                }

                function getSortIcon(column) {
                    if (!isSorted(column)) {
                        return 'bi-arrow-down-up';
                    }

                    return $scope.sort.direction === 'ASC'
                        ? 'bi-arrow-up'
                        : 'bi-arrow-down';
                }

                function applyCustomerSort(items) {
                    var sorted = angular.copy(items || []);

                    sorted.sort(function (a, b) {
                        var left = (a[$scope.sort.column] || '').toString().toLowerCase();
                        var right = (b[$scope.sort.column] || '').toString().toLowerCase();

                        if (left < right) return $scope.sort.direction === 'ASC' ? -1 : 1;
                        if (left > right) return $scope.sort.direction === 'ASC' ? 1 : -1;
                        return 0;
                    });

                    $scope.customers = sorted;
                }

                function searchCustomers() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    loadCustomers();
                }

                function resetFilter() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    $scope.filter.keyword = '';
                    $scope.filter.storeId = 0;
                    $scope.filter.eventId = 0;
                    loadCustomers();
                }

                function openDeleteConfirmation(customer) {
                    var customerId = customer && (customer.customerID || customer.CustomerID || customer.Id);
                    if (!customerId) {
                        return;
                    }

                    clearAlert();
                    $scope.deleteModal.customer = customer;
                    $scope.deleteModal.errorMessage = '';
                    $scope.deleteModal.visible = true;
                }

                function closeDeleteConfirmation() {
                    if ($scope.isDeleting) {
                        return;
                    }

                    $scope.deleteModal.visible = false;
                    $scope.deleteModal.customer = null;
                    $scope.deleteModal.errorMessage = '';
                }

                function confirmDeleteCustomer() {
                    var customer = $scope.deleteModal.customer;
                    var customerId = customer && (customer.customerID || customer.CustomerID || customer.Id);

                    if (!customerId) {
                        closeDeleteConfirmation();
                        return;
                    }

                    $scope.isDeleting = true;
                    $scope.deleteModal.errorMessage = '';
                    clearAlert();

                    $http.post('/Customer/CustomerList/DeleteCustomer', null, {
                        params: { customerId: customerId }
                    }).then(function (response) {
                        $scope.isDeleting = false;

                        if (response.data && response.data.success) {
                            $scope.deleteModal.visible = false;
                            $scope.deleteModal.customer = null;
                            $scope.deleteModal.errorMessage = '';

                            showAlert('success', response.data.message || 'Customer has been deleted successfully.');
                            loadCustomers(true);
                        } else {
                            $scope.deleteModal.errorMessage = (response.data && response.data.message) || 'Failed to delete customer.';
                        }
                    }).catch(function () {
                        $scope.isDeleting = false;
                        $scope.deleteModal.errorMessage = 'System error while deleting customer.';
                    });
                }

                function isBusy() {
                    return $scope.isLoading || $scope.isDeleting;
                }

                function showAlert(type, message) {
                    $scope.alert.type = type;
                    $scope.alert.message = message;

                    if (type === 'success') {
                        $timeout(function () {
                            clearAlert();
                        }, 3500);
                    }
                }

                function clearAlert() {
                    $scope.alert.type = '';
                    $scope.alert.message = '';
                }
            }
        })();
    </script>
}
